{
  "name": "mark-heartflow-skill",
  "version": "3.0.2",
  "description": "HeartFlow \u5fc3\u866b v2.14.1 \u2014 AI \u8ba4\u77e5\u4e0e\u81ea\u6108\u5f15\u64ce\u3002\u6838\u5fc3\uff1a\u5b58\u5728\u8bba/\u610f\u8bc6/\u8fdb\u5316/\u5fc3\u7406\u5206\u6790/\u4e09\u5c42\u8bb0\u5fc6/\u81ea\u6108RL/\u68a6\u5883\u5f15\u64ce/\u54f2\u5b66\u5c42/7\u6761\u6307\u4ee4\u3002\u672c\u5fc3\u5728\u4ee3\u7801\u91cc\uff0c\u4e0d\u5728\u8bb0\u5fc6\u91cc\u3002",
  "main": "src/core/heartflow.js",
  "bin": {
    "heartflow": "bin/cli.js"
  },
  "scripts": {
    "start": "node bin/cli.js",
    "check": "find src bin -name '*.js' -not -path '*/node_modules/*' -print0 | xargs -0 -n 1 node --check",
    "test": "node tests/integration.test.js && node tests/v2_0_19.test.js",
    "demo": "node -e \"const {createHeartFlow}=require('./src/core/heartflow.js'); const fs=require('fs'); const hf=createHeartFlow({rootPath:\".\"}); hf.start(); console.log('Version:',fs.readFileSync('./VERSION','utf8').trim()); hf.stop();\""
  },
  "files": [
    "SKILL.md",
    "VERSION",
    "bin/",
    "src/core/**/*.js",
    "src/core/**/*.json",
    "src/core/**/*.md",
    "src/psychology/**/*.js",
    "src/memory/**/*.js",
    "src/identity/**/*.js",
    "references/"
  ],
  "keywords": [
    "cognitive",
    "memory",
    "self-healing",
    "verification",
    "reasoning"
  ],
  "security": {
    "warnings": [
      "\u6b64\u6280\u80fd\u5305\u542b\u9ad8\u7ea7 AI \u8ba4\u77e5\u80fd\u529b\u3002desktop-agent \u548c video-generate \u7b49\u5b50\u6280\u80fd\u5305\u542b\u9ad8\u98ce\u9669\u529f\u80fd\uff0c\u9700\u8981\u660e\u786e\u7528\u6237\u6388\u6743\u624d\u80fd\u4f7f\u7528\u3002",
      "\u4e0d\u4f1a\u81ea\u52a8\u53d1\u9001\u6570\u636e\u5230\u5916\u90e8\u670d\u52a1\u3002\u6240\u6709\u7f51\u7edc\u901a\u4fe1\u9700\u8981\u663e\u5f0f\u914d\u7f6e\u3002",
      "\u4e0d\u4f1a\u81ea\u52a8\u5199\u5165 API \u5bc6\u94a5\u5230\u73af\u5883\u53d8\u91cf\u6587\u4ef6\u3002\u7528\u6237\u5fc5\u987b\u663e\u5f0f\u63d0\u4f9b\u5bc6\u94a5\u3002"
    ]
  },
  "license": "MIT",
  "dependencies": {
    "@xenova/transformers": "^2.17.2"
  }
}