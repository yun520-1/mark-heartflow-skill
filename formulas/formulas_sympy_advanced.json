      "category": "mathematics",
      "subcategory": "series",
      "source": "sympy_advanced"
    },
    {
      "id": "sympy_series_cos",
      "name": "余弦函数级数",
      "formula": "cos(x) = Σ_{n=0}^∞ (-1)^n x^{2n}/(2n)!",
      "category": "mathematics",
      "subcategory": "series",
      "source": "sympy_advanced"
    },
    {
      "id": "sympy_series_tan",
      "name": "正切函数级数",
      "formula": "tan(x) = Σ_{n=1}^∞ B_{2n} (-4)^n (1-4^n) x^{2n-1}/(2n)!",
      "category": "mathematics",
      "subcategory": "series",
      "source": "sympy_advanced"
    },
    {
      "id": "sympy_series_binomal",
      "name": "二项式级数",
      "formula": "(1+x)^α = Σ_{n=0}^∞ C(α, n) x^n",
      "category": "mathematics",
      "subcategory": "series",
      "source": "sympy_advanced"
    },
    {
      "id": "sympy_series_geometric",
