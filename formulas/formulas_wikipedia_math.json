      "formula": "F = MS_between/MS_within",
      "category": "mathematics",
      "subcategory": "statistics",
      "source": "wikipedia_manual_math"
    },
    {
      "id": "wiki_math_stat_regression",
      "name": "线性回归",
      "formula": "y = β_0 + β_1*x + ε",
      "category": "mathematics",
      "subcategory": "statistics",
      "source": "wikipedia_manual_math"
    },
    {
      "id": "wiki_math_stat_r_squared",
      "name": "决定系数",
      "formula": "R² = 1 - SS_res/SS_tot",
      "category": "mathematics",
      "subcategory": "statistics",
      "source": "wikipedia_manual_math"
    },
    {
      "id": "wiki_math_stat_p_value",
