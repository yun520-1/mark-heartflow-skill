      "source": "wikipedia_manual_math"
    },
    {
      "id": "wiki_math_prob_bayes",
      "name": "贝叶斯定理",
      "formula": "P(A|B) = P(B|A)*P(A)/P(B)",
      "category": "mathematics",
      "subcategory": "probability",
      "source": "wikipedia_manual_math"
    },
    {
      "id": "wiki_math_prob_total",
      "name": "全概率公式",
      "formula": "P(B) = Σ_i P(B|A_i)*P(A_i)",
      "category": "mathematics",
      "subcategory": "probability",
      "source": "wikipedia_manual_math"
    },
    {
      "id": "wiki_math_prob_expectation",
      "name": "期望",
      "formula": "E[X] = Σ x*P(X=x)",
      "category": "mathematics",
      "subcategory": "probability",
      "source": "wikipedia_manual_math"
    },
    {
      "id": "wiki_math_prob_variance",
      "name": "方差",
      "formula": "Var(X) = E[(X-μ)²]",
      "category": "mathematics",
      "subcategory": "probability",
      "source": "wikipedia_manual_math"
    },
    {
      "id": "wiki_math_prob_covariance",
      "name": "协方差",
      "formula": "Cov(X,Y) = E[(X-μ_X)(Y-μ_Y)]",
      "category": "mathematics",
      "subcategory": "probability",
      "source": "wikipedia_manual_math"
    },
    {
      "id": "wiki_math_prob_correlation",
      "name": "相关系数",
      "formula": "ρ(X,Y) = Cov(X,Y)/(σ_X*σ_Y)",
      "category": "mathematics",
      "subcategory": "probability",
      "source": "wikipedia_manual_math"
    },
    {
      "id": "wiki_math_prob_normal",
      "name": "正态分布",
      "formula": "f(x) = (1/√(2πσ²)) exp(-(x-μ)²/(2σ²))",
      "category": "mathematics",
      "subcategory": "probability",
      "source": "wikipedia_manual_math"
    },
    {
      "id": "wiki_math_prob_bernoulli",
      "name": "伯努利分布",
      "formula": "P(X=k) = p^k*(1-p)^{1-k}",
      "category": "mathematics",
      "subcategory": "probability",
      "source": "wikipedia_manual_math"
    },
    {
      "id": "wiki_math_prob_binomial",
      "name": "二项分布",
      "formula": "P(X=k) = C(n,k) p^k (1-p)^{n-k}",
      "category": "mathematics",
      "subcategory": "probability",
      "source": "wikipedia_manual_math"
    },
    {
      "id": "wiki_math_prob_poisson",
      "name": "泊松分布",
      "formula": "P(X=k) = (λ^k/k!) e^{-λ}",
      "category": "mathematics",
      "subcategory": "probability",
      "source": "wikipedia_manual_math"
    },
    {
      "id": "wiki_math_stat_sample_mean",
      "name": "样本均值",
      "formula": "x̄ = (1/n) Σ x_i",
      "category": "mathematics",
      "subcategory": "statistics",
      "source": "wikipedia_manual_math"
    },
    {
      "id": "wiki_math_stat_sample_variance",
      "name": "样本方差",
      "formula": "s² = (1/(n-1)) Σ (x_i - x̄)²",
      "category": "mathematics",
      "subcategory": "statistics",
      "source": "wikipedia_manual_math"
    },
    {
      "id": "wiki_math_stat_t_test",
      "name": "t 检验",
      "formula": "t = (x̄ - μ)/(s/√n)",
      "category": "mathematics",
      "subcategory": "statistics",
      "source": "wikipedia_manual_math"
    },
    {
      "id": "wiki_math_stat_anova",
