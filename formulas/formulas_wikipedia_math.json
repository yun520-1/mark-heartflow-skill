    {
      "id": "wiki_math_calc_derivative_def",
      "name": "导数定义",
      "formula": "f'(x) = lim_{h→0} (f(x+h)-f(x))/h",
      "category": "mathematics",
      "subcategory": "calculus",
      "source": "wikipedia_manual_math"
    },
    {
      "id": "wiki_math_calc_power_rule",
      "name": "幂函数求导",
      "formula": "d/dx x^n = n*x^{n-1}",
      "category": "mathematics",
      "subcategory": "calculus",
      "source": "wikipedia_manual_math"
    },
    {
      "id": "wiki_math_calc_product_rule",
      "name": "乘积法则",
      "formula": "d/dx [u*v] = u'*v + u*v'",
      "category": "mathematics",
      "subcategory": "calculus",
      "source": "wikipedia_manual_math"
    },
    {
      "id": "wiki_math_calc_chain_rule",
      "name": "链式法则",
      "formula": "d/dx f(g(x)) = f'(g(x)) * g'(x)",
      "category": "mathematics",
      "subcategory": "calculus",
      "source": "wikipedia_manual_math"
    },
    {
      "id": "wiki_math_calc_fundamental_theorem",
      "name": "微积分基本定理",
      "formula": "∫_a^b f(x) dx = F(b) - F(a)",
      "category": "mathematics",
      "subcategory": "calculus",
      "source": "wikipedia_manual_math"
    },
    {
      "id": "wiki_math_calc_lhopital",
      "name": "洛必达法则",
      "formula": "lim_{x→c} f(x)/g(x) = lim_{x→c} f'(x)/g'(x)",
      "category": "mathematics",
      "subcategory": "calculus",
      "source": "wikipedia_manual_math"
    },
    {
      "id": "wiki_math_calc_taylor",
      "name": "泰勒公式",
      "formula": "f(x) = f(a) + f'(a)(x-a) + f''(a)(x-a)²/2! + ...",
      "category": "mathematics",
      "subcategory": "calculus",
      "source": "wikipedia_manual_math"
    },
    {
      "id": "wiki_math_calc_maclaurin",
      "name": "麦克劳林公式",
      "formula": "f(x) = f(0) + f'(0)x + f''(0)x²/2! + ...",
      "category": "mathematics",
      "subcategory": "calculus",
      "source": "wikipedia_manual_math"
    },
    {
      "id": "wiki_math_la_determinant_2x2",
