      "category": "mathematics",
      "subcategory": "statistics",
      "source": "wikipedia_manual_math"
    },
    {
      "id": "wiki_math_stat_confidence_interval",
      "name": "置信区间",
      "formula": "x̄ ± z*σ/√n",
      "category": "mathematics",
      "subcategory": "statistics",
      "source": "wikipedia_manual_math"
    },
    {
      "id": "wiki_math_num_trapezoidal",
      "name": "梯形法则",
      "formula": "∫_a^b f(x) dx ≈ (h/2)[f(a) + 2Σ f(x_i) + f(b)]",
      "category": "mathematics",
      "subcategory": "numerical_analysis",
      "source": "wikipedia_manual_math"
    },
    {
      "id": "wiki_math_num_simpsons",
      "name": "辛普森法则",
      "formula": "∫_a^b f(x) dx ≈ (h/3)[f(a) + 4Σ f(x_{2i+1}) + 2Σ f(x_{2i}) + f(b)]",
      "category": "mathematics",
      "subcategory": "numerical_analysis",
      "source": "wikipedia_manual_math"
    },
    {
      "id": "wiki_math_num_euler_method",
      "name": "欧拉方法",
      "formula": "y_{n+1} = y_n + h*f(t_n, y_n)",
      "category": "mathematics",
      "subcategory": "numerical_analysis",
      "source": "wikipedia_manual_math"
    },
    {
      "id": "wiki_math_num_newton",
      "name": "牛顿法",
      "formula": "x_{n+1} = x_n - f(x_n)/f'(x_n)",
      "category": "mathematics",
      "subcategory": "numerical_analysis",
      "source": "wikipedia_manual_math"
    },
    {
      "id": "wiki_math_num_gauss_seidel",
      "name": "高斯-赛德尔",
      "formula": "x_i^{(k+1)} = (b_i - Σ_{j<i} a_{ij}x_j^{(k+1)} - Σ_{j>i} a_{ij}x_j^{(k)})/a_{ii}",
      "category": "mathematics",
      "subcategory": "numerical_analysis",
      "source": "wikipedia_manual_math"
    }
  ]
