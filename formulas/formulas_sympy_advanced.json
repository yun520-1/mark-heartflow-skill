      "subcategory": "general_relativity",
      "source": "sympy_advanced"
    },
    {
      "id": "sympy_geo_christoffel_symbols",
      "name": "克里斯托费尔符号",
      "formula": "Γ^μ_{νρ} = (1/2) g^{μσ} (∂_ν g_{ρσ} + ∂_ρ g_{νσ} - ∂_σ g_{νρ})",
      "category": "mathematics",
      "subcategory": "riemannian_geometry",
      "source": "sympy_advanced"
    },
    {
      "id": "sympy_geo_geodesic_equation_tensor",
      "name": "测地线方程（张量形式）",
      "formula": "d²x^μ/ds² + Γ^μ_{νρ} (dx^ν/ds) (dx^ρ/ds) = 0",
      "category": "mathematics",
      "subcategory": "riemannian_geometry",
      "source": "sympy_advanced"
    },
    {
      "id": "sympy_geo_stokes_theorem_general",
      "name": "斯托克斯定理（一般形式）",
      "formula": "∫_{∂M} ω = ∫_M dω",
      "category": "mathematics",
      "subcategory": "differential_geometry",
      "source": "sympy_advanced"
    },
    {
      "id": "sympy_geo_divergence_theorem_general",
      "name": "散度定理（一般形式）",
      "formula": "∫_M div X dV = ∫_{∂M} ⟨X, n⟩ dS",
      "category": "mathematics",
      "subcategory": "vector_calculus",
      "source": "sympy_advanced"
    }
  ]
