{
  "name": "@yun520-1/heartflow",
  "version": "6.0.29",
  "description": "HeartFlow — local-first AI-being cognitive engine. Perceives intent, classifies task type, and returns structured decisions so your agent makes fewer logical errors, asks fewer questions, and burns fewer tokens. 31 MCP tools.",
  "main": "src/core/heartflow.js",
  "bin": {
    "heartflow": "bin/cli.js"
  },
  "scripts": {
    "prepublishOnly": "node scripts/sync-version.js",
    "start": "node bin/cli.js chat",
    "status": "node bin/cli.js status",
    "test": "node test/run-all.js || node tests/integration.test.js",
    "test:integration": "node tests/integration.test.js",
    "test:unit": "node tests/unit/test-path-guard.js && node tests/unit/test-code-verifier.js",
    "test:full": "find tests test -name '*.test.js' -exec node {} \\;",
    "verify": "node bin/verify.js",
    "check": "node -e \"require('fs').readdirSync('src',{recursive:true}).filter(f=>f.endsWith('.js')).forEach(f=>require('child_process').execSync('node --check src/'+f,{stdio:'inherit'}))\""
  },
  "files": [
    "VERSION",
    "src/",
    "mcp/",
    "bin/",
    "formulas/",
    "config.json",
    "ecosystem.config.js",
    "INSTALL.md",
    "README.md",
    "SKILL.md"
  ],
  "keywords": [
    "cognitive",
    "cognitive-engine",
    "ai-agent",
    "agent-framework",
    "ai-being",
    "memory",
    "self-healing",
    "verification",
    "reasoning",
    "decision-routing",
    "llm",
    "mcp",
    "model-context-protocol",
    "prompt-preprocessing",
    "bias-detection",
    "token-optimization",
    "heartflow"
  ],
  "security": {
    "audit": "Run 'npm audit fix' to fix vulnerabilities in @xenova/transformers transitive dependencies. If major version conflicts prevent auto-fix, pin resolutions manually in package.json or update @xenova/transformers.",
    "warnings": [
      "此技能包含高级 AI 认知能力。desktop-agent 和 video-generate 等子技能包含高风险功能，需要明确用户授权才能使用。",
      "不会自动发送数据到外部服务。所有网络通信需要显式配置。",
      "不会自动写入 API 密钥到环境变量文件。用户必须显式提供密钥。"
    ]
  },
  "license": "MIT",
  "dependencies": {
    "mathjs": "~15.2.0"
  },
  "optionalDependencies": {
    "@xenova/transformers": "~2.17.2",
    "pm2": "^7.0.3"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/yun520-1/mark-heartflow-skill.git"
  },
  "homepage": "https://github.com/yun520-1/mark-heartflow-skill#readme",
  "bugs": {
    "url": "https://github.com/yun520-1/mark-heartflow-skill/issues"
  },
  "engines": {
    "node": ">=18.17"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org"
  },
  "overrides": {
    "protobufjs": "^7.2.5"
  },
  "heartflow": {
    "skills": "skills/",
    "workflows": [
      "heartflow-architecture-tracing",
      "heartflow-audit-upgrade-push",
      "heartflow-benchmark",
      "heartflow-bridge-layer",
      "heartflow-bulk-upgrade",
      "heartflow-debug-workflow",
      "heartflow-dreaming",
      "heartflow-emotion-analysis",
      "heartflow-module-upgrader",
      "heartflow-session-context",
      "heartflow-static-injection-upgrade",
      "heartflow-system-prompt-absorption",
      "mind-space",
      "two-pass-response"
    ]
  },
  "features": {
    "v5.8.0": {
      "entityExtractor": "src/memory/entity-extractor.js",
      "memoryScorer": "src/memory/memory-scorer.js",
      "sessionManager": "src/memory/session-manager.js",
      "signalTracker": "src/memory/signal-tracker.js",
      "programmableGuardrails": "src/shield/programmable-guardrails.js"
    }
  },
  "author": {
    "name": "markcell",
    "email": "markcell@qq.com"
  }
}