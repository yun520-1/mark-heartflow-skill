      "subcategory": "series",
      "source": "wikipedia_advanced"
    },
    {
      "id": "adv_series_legendre",
      "name": "Legendre series",
      "formula": "P_n(x) = sum (-1)^k (2n-2k)!/(2^n k! (n-k)! (n-2k)!) x^{n-2k}",
      "category": "mathematics",
      "subcategory": "series",
      "source": "wikipedia_advanced"
    },
    {
