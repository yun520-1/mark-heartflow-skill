# HeartFlow Skill - 发布配置
# 包含所有核心文件，确保用户安装后可正常运行

# ========== 排除 ==========

# Git 相关
.git/
.gitignore

# 缓存和临时文件
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
*.so
*.egg
*.egg-info/
dist/
build/

# 开发文件
*.log
*.tmp
*.temp
.DS_Store
Thumbs.db

# 临时目录
temp/
tmp/
downloads/
archive/

# 测试文件（可选，发布时不需要）
test_*.py
*_test.py

# 文档（保留核心文档）
docs/
canvas/

# 节点模块（如果有）
node_modules/

# ========== 包含 ==========

# 核心配置文件
!SKILL.md
!VERSION.txt
!SECURITY.md
!PRIVACY_PROTECTION.md
!clawhub.json
!package.json
!install.sh
!verify_install.py
!README.md

# 所有脚本文件
!scripts/
!scripts/*.py
!scripts/*.js
!scripts/*.sh

# 可执行文件
!bin/

# 配置文件
!config/

# 数据目录（如果需要）
!data/
!dict-data/
