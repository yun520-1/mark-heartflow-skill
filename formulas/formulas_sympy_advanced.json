      "formula": "d²x^μ/ds² + Γ^μ_{νρ} (dx^ν/ds) (dx^ρ/ds) = 0",
      "category": "mathematics",
      "subcategory": "riemannian_geometry",
      "source": "sympy_advanced"
    },
    {
      "id": "sympy_geo_riemann_tensor_components",
      "name": "黎曼张量分量",
      "formula": "R^ρ_{σμν} = ∂_μ Γ^ρ_{νσ} - ∂_ν Γ^ρ_{μσ} + Γ^ρ_{μλ} Γ^λ_{νσ} - Γ^ρ_{νλ} Γ^λ_{μσ}",
      "category": "mathematics",
      "subcategory": "riemannian_geometry",
      "source": "sympy_advanced"
    },
    {
      "id": "sympy_geo_ricci_tensor_components",
