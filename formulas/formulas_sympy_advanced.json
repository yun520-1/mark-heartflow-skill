      "subcategory": "series",
      "source": "sympy_advanced"
    },
    {
      "id": "sympy_series_harmonic",
      "name": "调和级数",
      "formula": "Σ_{n=1}^∞ 1/n = ∞ (发散)",
      "category": "mathematics",
      "subcategory": "series",
      "source": "sympy_advanced"
    },
    {
      "id": "sympy_series_alternating_harmonic",
