{
  "metadata": {
    "version": "1.0.0",
    "source": "Manual collection (Wikipedia + textbooks)",
    "total_formulas": 13
  },
  "formulas": [
    {
      "id": "pythagorean_theorem",
      "name": "勾股定理",
      "category": "mathematics",
      "subcategory": "geometry",
      "formula": "a^2 + b^2 = c^2",
      "latex": "a^2 + b^2 = c^2"
    },
    {
      "id": "quadratic_formula",
      "name": "一元二次方程求根公式",
      "category": "mathematics",
      "subcategory": "algebra",
      "formula": "x = (-b ± sqrt(b^2 - 4*a*c)) / (2*a)",
      "latex": "x = \\frac{-b \\pm \\sqrt{b^2 - 4ac}}{2a}"
    },
    {
      "id": "euler_formula",
      "name": "欧拉公式",
      "category": "mathematics",
      "subcategory": "complex_analysis",
      "formula": "e^(i*pi) + 1 = 0",
      "latex": "e^{i\\pi} + 1 = 0"
    },
    {
      "id": "binomial_theorem",
      "name": "二项式定理",
      "category": "mathematics",
      "subcategory": "algebra",
      "formula": "(a + b)^n = sum(C(n,k) * a^(n-k) * b^k, k=0 to n)",
      "latex": "(a + b)^n = \\sum_{k=0}^{n} \\binom{n}{k} a^{n-k} b^k"
    },
    {
      "id": "newton_second_law",
      "name": "牛顿第二定律",
      "category": "physics",
      "subcategory": "classical_mechanics",
      "formula": "F = m * a",
      "latex": "F = m \\cdot a"
    },
    {
      "id": "ohm_law",
      "name": "欧姆定律",
      "category": "physics",
      "subcategory": "electromagnetism",
      "formula": "V = I * R",
      "latex": "V = I \\cdot R"
    },
    {
      "id": "coulomb_law",
      "name": "库仑定律",
      "category": "physics",
      "subcategory": "electromagnetism",
      "formula": "F = k * (q1 * q2) / r^2",
      "latex": "F = k \\frac{q_1 q_2}{r^2}"
    },
    {
      "id": "faraday_law",
      "name": "法拉第电磁感应定律",
      "category": "physics",
      "subcategory": "electromagnetism",
      "formula": "emf = -d(Phi)/dt",
      "latex": "\\mathcal{E} = -\\frac{d\\Phi_B}{dt}"
    },
    {
      "id": "maxwell_equations",
      "name": "麦克斯韦方程组",
      "category": "physics",
      "subcategory": "electromagnetism",
      "formula": "∇·E = ρ/ε0, ∇×E = -∂B/∂t, ∇·B = 0, ∇×B = μ0J + μ0ε0∂E/∂t",
      "latex": "\\nabla \\cdot \\mathbf{E} = \\frac{\\rho}{\\varepsilon_0}, \\ldots"
    },
    {
      "id": "schrodinger_equation",
      "name": "薛定谔方程",
      "category": "physics",
      "subcategory": "quantum_mechanics",
      "formula": "i*ħ*∂ψ/∂t = H*ψ",
      "latex": "i\\hbar \\frac{\\partial \\psi}{\\partial t} = \\hat{H} \\psi"
    },
    {
      "id": "heisenberg_uncertainty",
      "name": "海森堡不确定性原理",
      "category": "physics",
      "subcategory": "quantum_mechanics",
      "formula": "Δx * Δp >= ħ/2",
      "latex": "\\Delta x \\Delta p \\geq \\frac{\\hbar}{2}"
    },
    {
      "id": "ideal_gas_law",
      "name": "理想气体状态方程",
      "category": "chemistry",
      "subcategory": "thermodynamics",
      "formula": "P * V = n * R * T",
      "latex": "PV = nRT"
    },
    {
      "id": "arrhenius_equation",
      "name": "阿伦尼乌斯方程",
      "category": "chemistry",
      "subcategory": "kinetics",
      "formula": "k = A * exp(-Ea/(R*T))",
      "latex": "k = A e^{-E_a/(RT)}"
    }
  ]
}