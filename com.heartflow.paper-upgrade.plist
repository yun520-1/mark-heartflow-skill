<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.heartflow.paper-upgrade</string>
    <key>ProgramArguments</key>
    <array>
        <string>/bin/bash</string>
        <string>-c</string>
        <string>cd /Users/apple/.hermes/skills/ai/mark-heartflow-skill && /opt/homebrew/bin/node cron/upgrade-runner.mjs >> logs/paper-upgrade-cron.log 2>&1</string>
    </array>
    <key>StartInterval</key>
    <integer>1200</integer>
    <key>RunAtLoad</key>
    <true/>
    <key>StandardOutPath</key>
    <string>/Users/apple/.hermes/skills/ai/mark-heartflow-skill/logs/paper-upgrade.stdout.log</string>
    <key>StandardErrorPath</key>
    <string>/Users/apple/.hermes/skills/ai/mark-heartflow-skill/logs/paper-upgrade.stderr.log</string>
</dict>
</plist>