      "/cbt",
      "/stoic",
      "/act",
      "/attachment",
      "/mindful",
      "/narrative",
      "/wisdom",
      "/moral",
      "/agency",
      "/identity",
      "/emotion",
      "/temporal",
      "/relational",
      "/awe",
      "/consciousness",
      "/cognitive"
    ],
    "handler": "skill/handlers/openclaw.js",
    "config": {
      "dataDir": "~/.openclaw/workspace/heartflow/data",
