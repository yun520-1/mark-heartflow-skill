      "subcategory": "integrals",
      "source": "wikipedia_advanced"
    },
    {
      "id": "adv_series_bessel",
      "name": "Bessel series",
      "formula": "J_alpha(x) = sum (-1)^k (x/2)^{alpha+2k}/(k! Gamma(alpha+k+1))",
