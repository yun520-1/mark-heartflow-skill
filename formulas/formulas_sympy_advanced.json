      "subcategory": "quantum_mechanics",
      "source": "sympy_advanced"
    },
    {
      "id": "sympy_pde_dirac_1d",
      "name": "一维狄拉克方程",
      "formula": "i ℏ ∂ψ/∂t = -i ℏ c α ∂ψ/∂x + β m c² ψ",
      "category": "physics",
      "subcategory": "quantum_field_theory",
      "source": "sympy_advanced"
    },
    {
      "id": "sympy_pde_klein_gordon",
      "name": "克莱因-戈尔登方程",
      "formula": "∂²φ/∂t² - c² ∇²φ + (m c²/ℏ)² φ = 0",
      "category": "physics",
      "subcategory": "quantum_field_theory",
      "source": "sympy_advanced"
    },
    {
      "id": "sympy_pde_navier_stokes_2d",
