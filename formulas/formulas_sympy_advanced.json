      "formula": "δF/δf(x) = ∂L/∂f - d/dx (∂L/∂f')",
      "category": "mathematics",
      "subcategory": "calculus_variations",
      "source": "sympy_advanced"
    },
    {
      "id": "sympy_var_hamilton_principle",
      "name": "哈密顿原理",
      "formula": "δ ∫ L(q, q', t) dt = 0",
      "category": "physics",
      "subcategory": "classical_mechanics",
      "source": "sympy_advanced"
    },
    {
