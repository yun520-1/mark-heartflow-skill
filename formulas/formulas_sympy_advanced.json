  "formulas": [
    {
      "id": "sympy_spec_laguerre_generalized",
      "name": "广义拉盖尔多项式",
      "formula": "L_n^α(x) = Σ (-1)^k C(n+α, n-k) x^k/k!",
      "category": "mathematics",
      "subcategory": "special_functions",
      "source": "sympy_advanced"
    },
    {
      "id": "sympy_spec_hermite_probabilist",
      "name": "概率学家厄米多项式",
      "formula": "He_n(x) = (-1)^n e^{x²/2} d^n/dx^n e^{-x²/2}",
      "category": "mathematics",
      "subcategory": "special_functions",
      "source": "sympy_advanced"
    },
    {
      "id": "sympy_spec_gegenbauer",
      "name": "盖根鲍尔多项式",
      "formula": "C_n^{(λ)}(x) = Σ (-1)^k Γ(n-2k+λ) (2x)^{n-2k} / (k! Γ(λ+k))",
      "category": "mathematics",
      "subcategory": "special_functions",
      "source": "sympy_advanced"
    },
    {
      "id": "sympy_spec_jacobi",
      "name": "雅可比多项式",
      "formula": "P_n^{(α,β)}(x) = (α+1)_n / n! * ₂F₁(-n, n+α+β+1; α+1; (1-x)/2)",
      "category": "mathematics",
      "subcategory": "special_functions",
      "source": "sympy_advanced"
    },
    {
      "id": "sympy_spec_legendre_assoc",
      "name": "连带勒让德多项式",
      "formula": "P_n^m(x) = (-1)^m (1-x²)^{m/2} d^m/dx^m P_n(x)",
      "category": "mathematics",
      "subcategory": "special_functions",
      "source": "sympy_advanced"
    },
    {
      "id": "sympy_spec_spherical_harmonic",
      "name": "球谐函数",
      "formula": "Y_l^m(θ,φ) = (-1)^m sqrt((2l+1)/(4π) * (l-m)!/(l+m)!) P_l^m(cosθ) e^{i m φ}",
      "category": "mathematics",
      "subcategory": "special_functions",
      "source": "sympy_advanced"
    },
    {
      "id": "sympy_spec_bessel_i",
      "name": "修正贝塞尔函数 I_α(x)",
      "formula": "I_α(x) = i^{-α} J_α(i x)",
      "category": "mathematics",
      "subcategory": "special_functions",
      "source": "sympy_advanced"
    },
    {
      "id": "sympy_spec_bessel_k",
      "name": "修正贝塞尔函数 K_α(x)",
      "formula": "K_α(x) = π/2 * I_{-α}(x) - I_α(x) / sin(απ)",
      "category": "mathematics",
      "subcategory": "special_functions",
      "source": "sympy_advanced"
    },
    {
      "id": "sympy_spec_hankel1",
      "name": "汉克尔函数第一类",
      "formula": "H_α^{(1)}(x) = J_α(x) + i Y_α(x)",
      "category": "mathematics",
      "subcategory": "special_functions",
      "source": "sympy_advanced"
    },
    {
      "id": "sympy_spec_hankel2",
      "name": "汉克尔函数第二类",
      "formula": "H_α^{(2)}(x) = J_α(x) - i Y_α(x)",
      "category": "mathematics",
      "subcategory": "special_functions",
      "source": "sympy_advanced"
    },
    {
      "id": "sympy_int_gamma_upper",
      "name": "上不完全伽马函数",
      "formula": "Γ(a, x) = ∫_x^∞ t^{a-1} e^{-t} dt",
      "category": "mathematics",
      "subcategory": "integrals",
      "source": "sympy_advanced"
    },
    {
      "id": "sympy_int_gamma_lower",
      "name": "下不完全伽马函数",
      "formula": "γ(a, x) = ∫_0^x t^{a-1} e^{-t} dt",
      "category": "mathematics",
      "subcategory": "integrals",
      "source": "sympy_advanced"
    },
    {
      "id": "sympy_int_beta_incomplete",
      "name": "不完全贝塔函数",
      "formula": "B(x; a, b) = ∫_0^x t^{a-1} (1-t)^{b-1} dt",
      "category": "mathematics",
      "subcategory": "integrals",
      "source": "sympy_advanced"
    },
    {
      "id": "sympy_int_elliptic_f",
      "name": "不完全椭圆积分第一类",
      "formula": "F(φ, k) = ∫_0^φ dθ / √(1 - k² sin²θ)",
      "category": "mathematics",
      "subcategory": "integrals",
      "source": "sympy_advanced"
    },
    {
      "id": "sympy_int_elliptic_e",
      "name": "不完全椭圆积分第二类",
      "formula": "E(φ, k) = ∫_0^φ √(1 - k² sin²θ) dθ",
      "category": "mathematics",
      "subcategory": "integrals",
      "source": "sympy_advanced"
    },
    {
      "id": "sympy_int_elliptic_pi",
      "name": "不完全椭圆积分第三类",
      "formula": "Π(n; φ, k) = ∫_0^φ dθ / ((1 - n sin²θ) √(1 - k² sin²θ))",
      "category": "mathematics",
      "subcategory": "integrals",
      "source": "sympy_advanced"
    },
    {
      "id": "sympy_int_fresnel_s",
      "name": "菲涅尔 S 积分",
      "formula": "S(x) = ∫_0^x sin(π t²/2) dt",
      "category": "mathematics",
      "subcategory": "integrals",
      "source": "sympy_advanced"
    },
    {
      "id": "sympy_int_fresnel_c",
      "name": "菲涅尔 C 积分",
      "formula": "C(x) = ∫_0^x cos(π t²/2) dt",
      "category": "mathematics",
      "subcategory": "integrals",
      "source": "sympy_advanced"
    },
    {
      "id": "sympy_int_si",
      "name": "正弦积分",
      "formula": "Si(x) = ∫_0^x sin(t)/t dt",
      "category": "mathematics",
      "subcategory": "integrals",
      "source": "sympy_advanced"
    },
    {
      "id": "sympy_int_ci",
      "name": "余弦积分",
      "formula": "Ci(x) = -∫_x^∞ cos(t)/t dt",
      "category": "mathematics",
      "subcategory": "integrals",
      "source": "sympy_advanced"
    },
    {
      "id": "sympy_series_exp",
      "name": "指数函数级数",
      "formula": "e^x = Σ_{n=0}^∞ x^n/n!",
      "category": "mathematics",
      "subcategory": "series",
      "source": "sympy_advanced"
    },
    {
      "id": "sympy_series_log",
